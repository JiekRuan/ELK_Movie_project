{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "filter": {
        "english_stop": {
          "type": "stop",
          "stopwords": "_english_"
        },
        "english_stemmer": {
          "type": "stemmer",
          "language": "english"
        }
      },
      "analyzer": {
        "movie_text_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "english_stop",
            "english_stemmer",
            "asciifolding"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "movie_id": {
        "type": "integer"
      },
      "title": {
        "type": "text",
        "analyzer": "movie_text_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 512
          }
        }
      },
      "overview": {
        "type": "text",
        "analyzer": "movie_text_analyzer"
      },
      "original_language": {
        "type": "keyword"
      },
      "release_date": {
        "type": "date"
      },
      "release_year": {
        "type": "integer"
      },
      "popularity": {
        "type": "float"
      },
      "vote_average": {
        "type": "float"
      },
      "vote_count": {
        "type": "integer"
      }
    }
  }
}
